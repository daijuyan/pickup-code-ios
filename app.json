{
  "expo": {
    "name": "快递取件码",
    "slug": "pickup-code",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.codex.pickupcode",
      "jsEngine": "jsc",
      "newArchEnabled": false
